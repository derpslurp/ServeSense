# Optional: for scripts/download_roboflow_volleyball.py
# Get your key from https://app.roboflow.com/settings/api
# ROBOFLOW_API_KEY=

# Optional: improve YOLO pose annotation accuracy
# POSE_MODEL=yolov8s-pose.pt   # Use larger model (s/m/l) for better accuracy (slower)
# POSE_MODEL=runs/pose/volleyball/weights/best.pt  # Use fine-tuned volleyball pose model (after scripts/train_pose_model.py)
# POSE_IMGSZ=832               # Higher resolution = more accurate (default 640)
# POSE_KP_CONF=0.25            # Lower = include more keypoints (default 0.25)
